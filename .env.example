# --- CRM Neela : variables d'environnement ---

# Obligatoire (CRM + base)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
NEELA_CRM_PASSWORD=

# ============================================================
# Intégrations OPTIONNELLES (Lot F).
# Chaque brique se désactive proprement si sa variable est absente :
# le CRM reste pleinement fonctionnel sans aucune de ces clés.
# ============================================================

# Téléphonie : "twilio" ou "ringover" (sinon clic-pour-appeler tel: natif)
TELEPHONY_PROVIDER=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=
RINGOVER_API_KEY=

# IA — transcription (Whisper) + résumé des appels enregistrés
OPENAI_API_KEY=

# IA Ad Planner — suggestions d'hypothèses + explication des plans (Claude / Anthropic).
# L'IA n'invente JAMAIS de population/audience : ces chiffres viennent des données réelles.
ANTHROPIC_API_KEY=

# Ad Planner — audience Meta RÉELLE (optionnel, étape e). Sans ces clés : modèle de
# pénétration par âge. Token system-user (jamais exposé au client) + ad account act_<id>.
META_SYSTEM_USER_TOKEN=
META_AD_ACCOUNT_ID=

# Google Calendar (OAuth — réservation + synchro)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=

# Meta Lead Ads (webhook → création de fiche en temps réel)
META_VERIFY_TOKEN=
META_APP_SECRET=
META_PAGE_ACCESS_TOKEN=
